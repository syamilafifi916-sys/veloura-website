# Firebase Admin SDK service account JSON string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID"}

# Bayarcash credentials from merchant console
BAYARCASH_PAT=your_personal_access_token
BAYARCASH_SECRET_KEY=your_api_secret_key
BAYARCASH_PORTAL_KEY=your_portal_key
BAYARCASH_BASE_URL=https://api.bayar.cash

# Website URL
SITE_URL=https://your-vercel-domain.vercel.app
ADMIN_EMAIL=admin@veloura.my
